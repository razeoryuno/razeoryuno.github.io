---
import { siteConfig } from "../config";
---

<div
  id="hero"
  class="relative isolate overflow-hidden min-h-screen flex flex-col justify-center"
  style={`background: var(--bg-base); --accent: ${siteConfig.accentColor}`}
>
  <!-- Subtle dot grid -->
  <div
    class="absolute inset-0 -z-20 opacity-[0.35]"
    style="background-image: radial-gradient(circle, #2d2d2d 1px, transparent 1px); background-size: 32px 32px;"
  ></div>

  <!-- Accent corner glow -->
  <div
    class="absolute -z-10 pointer-events-none"
    style={`top: -10%; left: -5%; width: 700px; height: 700px; border-radius: 50%; background: radial-gradient(circle, ${siteConfig.accentColor}14 0%, transparent 65%);`}
  ></div>

  <!-- Content -->
  <div class="mx-auto w-full p-8 sm:p-16 md:px-24 md:py-0">
    <!-- Engine label -->
    <div class="flex items-center gap-3 mb-10 animate-fade-in">
      <div class="w-8 h-px" style={`background: ${siteConfig.accentColor}`}></div>
      <span class="mono text-xs tracking-[0.25em] uppercase text-[var(--text-muted)]">
        Game Developer Portfolio
      </span>
    </div>

    <!-- Greeting -->
    <p class="text-lg font-medium text-[var(--text-secondary)] mb-2 animate-fade-in delay-100">
      Hello,
    </p>

    <!-- Name -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight text-[var(--text-primary)] leading-none animate-fade-in delay-200">
      I'm&nbsp;<span style={`color: ${siteConfig.accentColor}; text-shadow: 0 0 40px ${siteConfig.accentColor}40`}>
        {siteConfig.name}
      </span>
    </h1>

    <!-- Title -->
    <p
      class="mono mt-6 text-sm sm:text-base text-[var(--text-secondary)] animate-fade-in delay-400"
    >
      <span style={`color: ${siteConfig.accentColor}`}>&gt;&nbsp;</span>{siteConfig.title}
    </p>

    <!-- Social icons -->
    <div class="flex gap-5 mt-10 animate-fade-in delay-600">
      {siteConfig.social?.email && (
        <a href={`mailto:${siteConfig.social.email}`} aria-label="Email" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"/>
            <path d="M3 7l9 6l9 -6"/>
          </svg>
        </a>
      )}
      {siteConfig.social?.linkedin && (
        <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <path d="M8 11v5"/><path d="M8 8v.01"/><path d="M12 16v-5"/>
            <path d="M16 16v-3a2 2 0 1 0 -4 0"/>
            <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z"/>
          </svg>
        </a>
      )}
      {siteConfig.social?.github && (
        <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"/>
          </svg>
        </a>
      )}
    </div>
  </div>

  <!-- Bottom scroll hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 mono text-xs text-[var(--text-muted)] tracking-widest animate-fade-in delay-600 flex flex-col items-center gap-2">
    <span>SCROLL</span>
    <div class="w-px h-8" style={`background: linear-gradient(to bottom, ${siteConfig.accentColor}80, transparent)`}></div>
  </div>
</div>

<style>
  .social-icon {
    color: var(--text-muted);
    transition: color 0.2s, filter 0.2s;
  }
  .social-icon:hover {
    color: var(--accent);
    filter: drop-shadow(0 0 6px var(--accent));
  }
</style>
