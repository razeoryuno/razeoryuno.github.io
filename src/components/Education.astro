---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{hasEducation && (
  <section id="education" class="p-8 sm:p-12 md:p-16 lg:p-24" style="background: var(--bg-base)">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">

      <!-- Section header -->
      <div class="lg:col-span-4">
        <p class="mono text-xs tracking-[0.2em] text-[var(--text-muted)] uppercase mb-2">SECTION_04</p>
        <h2 class="text-4xl sm:text-5xl xl:text-6xl font-bold text-[var(--text-primary)]">Education</h2>
        <div class="w-16 h-0.5 mt-3" style={`background: ${siteConfig.accentColor}`}></div>
      </div>

      <!-- Cards -->
      <div class="lg:col-span-8 space-y-4">
        {siteConfig.education.map((edu) => (
          <div class="card-panel p-4 sm:p-5">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-3">
              <div>
                <h3 class="font-semibold text-[var(--text-primary)]">{edu.degree}</h3>
                <p class="text-sm" style={`color: ${siteConfig.accentColor}`}>{edu.school}</p>
              </div>
              <span class="mono text-xs text-[var(--text-muted)] shrink-0">{edu.dateRange}</span>
            </div>

            {edu.achievements && edu.achievements.length > 0 && (
              <ul class="space-y-2 mt-3" style="border-top: 1px solid var(--border); padding-top: 12px">
                {edu.achievements.map((achievement) => (
                  <li class="flex items-start gap-3 text-sm text-[var(--text-secondary)]">
                    <span class="mt-2 w-1 h-1 rounded-full shrink-0" style={`background: ${siteConfig.accentColor}`}></span>
                    {achievement}
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>

    </div>
  </section>
)}
