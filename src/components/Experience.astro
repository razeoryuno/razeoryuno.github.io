---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{hasExperience && (
  <section id="experience" class="section-pad" aria-labelledby="experience-heading" style="background: var(--bg-panel)">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10 items-start">

      <!-- Section header -->
      <div class="lg:col-span-2">
        <p class="mono text-xs tracking-[0.2em] text-[var(--text-muted)] uppercase mb-2">SECTION_03</p>
        <h2 id="experience-heading" class="text-3xl sm:text-4xl xl:text-5xl font-bold text-[var(--text-primary)]">Experience</h2>
        <div class="w-12 h-0.5 mt-3 accent-rule"></div>
      </div>

      <!-- Timeline -->
      <div class="lg:col-span-10">
        <div class="relative pl-5" style="border-left: 1px solid var(--border)">
          {siteConfig.experience.map((exp, index) => (
            <div class={`relative pb-10 last:pb-0`}>
              <!-- Timeline dot -->
              <div
                class="absolute -left-[21px] top-1 w-2.5 h-2.5 rounded-full border-2"
                style={`border-color: ${siteConfig.accentColor}; background: var(--bg-base)`}
              ></div>

              <!-- Entry card -->
              <div class="card-panel p-4 sm:p-5 ml-4">
                <!-- Header -->
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-3">
                  <div>
                    <h3 class="font-semibold text-[var(--text-primary)]">{exp.title}</h3>
                    <p class="text-sm" style={`color: ${siteConfig.accentColor}`}>{exp.company}</p>
                  </div>
                  <span class="mono text-xs text-[var(--text-secondary)] shrink-0">{exp.dateRange}</span>
                </div>

                <!-- Bullets -->
                <ul class="space-y-2">
                  {exp.bullets.map((bullet) => (
                    <li class="flex items-start gap-3 text-sm text-[var(--text-secondary)]">
                      <span class="mt-2 w-1 h-1 rounded-full shrink-0" style={`background: ${siteConfig.accentColor}`}></span>
                      {bullet}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>
)}
