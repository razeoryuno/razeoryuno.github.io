---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;

function toEmbedUrl(watchUrl: string) {
  const id = new URL(watchUrl).searchParams.get('v');
  return `https://www.youtube.com/embed/${id}?rel=0&modestbranding=1`;
}
---

{hasProjects && (
  <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24" style="background: var(--bg-base)">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">

      <!-- Section header -->
      <div class="lg:col-span-4">
        <p class="mono text-xs tracking-[0.2em] text-[var(--text-muted)] uppercase mb-2">SECTION_02</p>
        <h2 class="text-4xl sm:text-5xl xl:text-6xl font-bold text-[var(--text-primary)]">Projects</h2>
        <div class="w-16 h-0.5 mt-3" style={`background: ${siteConfig.accentColor}`}></div>
      </div>

      <!-- Asset cards -->
      <div class="lg:col-span-8 space-y-4">
        {siteConfig.projects.map((project, index) => (
          <div class="asset-card card-panel group">

            <!-- Screenshot / video gallery -->
            {(project.images?.length || project.videos?.length) && (
              <div class="asset-gallery" style="border-bottom: 1px solid var(--border)">
                {project.images?.map((src, i) => (
                  <div class={`gallery-slot gallery-slot--${project.imageLayout ?? "landscape"}`}>
                    <img
                      src={src}
                      alt={`${project.name} screenshot ${i + 1}`}
                      class="gallery-img"
                      loading="lazy"
                      data-lightbox
                    />
                  </div>
                ))}
                {project.videos?.map((url) => (
                  <div class={`gallery-slot gallery-slot--${project.imageLayout ?? "landscape"}`}>
                    <iframe
                      src={toEmbedUrl(url)}
                      class="gallery-video"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                      loading="lazy"
                    />
                  </div>
                ))}
              </div>
            )}

            <!-- Card header bar -->
            <div class="asset-header flex items-center justify-between px-4 py-2.5"
              style="border-bottom: 1px solid var(--border)">
              <div class="flex items-center gap-3">
                <span class="mono text-xs text-[var(--text-muted)]">
                  {String(index + 1).padStart(2, '0')}.asset
                </span>
                <span class="text-sm font-semibold text-[var(--text-primary)]">{project.name}</span>
              </div>
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mono text-xs tracking-wider uppercase transition-colors"
                  style={`color: ${siteConfig.accentColor}`}
                  aria-label={`Open ${project.name}`}
                >
                  OPEN ↗
                </a>
              )}
            </div>

            <!-- Description -->
            <div class="px-4 py-4">
              <p class="text-sm sm:text-base text-[var(--text-secondary)] leading-relaxed">
                {project.description}
              </p>
            </div>

            <!-- Metadata bar -->
            {(project.role || project.engine || project.genre || project.devTime || project.status) && (
              <div class="px-4 py-3 flex flex-wrap gap-x-6 gap-y-1"
                style="border-top: 1px solid var(--border); background: rgba(255,255,255,0.02)">
                {project.role && (
                  <span class="mono text-xs text-[var(--text-muted)]">
                    ROLE: <span class="text-[var(--text-secondary)]">{project.role}</span>
                  </span>
                )}
                {project.engine && (
                  <span class="mono text-xs text-[var(--text-muted)]">
                    ENGINE: <span class="text-[var(--text-secondary)]">{project.engine}</span>
                  </span>
                )}
                {project.genre && (
                  <span class="mono text-xs text-[var(--text-muted)]">
                    GENRE: <span class="text-[var(--text-secondary)]">{project.genre}</span>
                  </span>
                )}
                {project.devTime && (
                  <span class="mono text-xs text-[var(--text-muted)]">
                    DEV TIME: <span class="text-[var(--text-secondary)]">{project.devTime}</span>
                  </span>
                )}
                {project.status && (
                  <span class="mono text-xs text-[var(--text-muted)]">
                    STATUS: {project.status === "Out of Service"
                      ? <span style="color: #666">✕ OUT OF SERVICE</span>
                      : project.status === "Unreleased"
                      ? <span style="color: #888">◌ UNRELEASED</span>
                      : project.status === "Thesis"
                      ? <span style="color: #888">◈ THESIS</span>
                      : <span style={`color: ${siteConfig.accentColor}`}>✓ {project.status.toUpperCase()}</span>
                    }
                  </span>
                )}
              </div>
            )}

            <!-- Skill tags -->
            {project.skills && project.skills.length > 0 && (
              <div class="px-4 py-3 flex flex-wrap gap-2"
                style="border-top: 1px solid var(--border)">
                {project.skills.map((skill) => (
                  <span class="tag">{skill}</span>
                ))}
              </div>
            )}

          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" role="dialog" aria-modal="true" aria-label="Image preview">
    <button id="lightbox-close" aria-label="Close">ESC ✕</button>
    <img id="lightbox-img" src="" alt="" />
  </div>
)}

<style>
  .asset-card {
    overflow: hidden;
    transition: box-shadow 0.25s ease;
  }
  .asset-card:hover {
    box-shadow: 0 0 0 1px var(--border-bright), 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .asset-gallery {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    background: #0a0a0a;
  }

  .asset-gallery::-webkit-scrollbar {
    height: 3px;
  }
  .asset-gallery::-webkit-scrollbar-track {
    background: var(--border);
  }
  .asset-gallery::-webkit-scrollbar-thumb {
    background: var(--border-bright);
    border-radius: 2px;
  }

  .gallery-slot {
    flex-shrink: 0;
    overflow: hidden;
    scroll-snap-align: start;
  }

  /* Portrait — mobile game screenshots (9:16) */
  .gallery-slot--portrait {
    width: 180px;
    height: 320px;
  }

  /* Landscape — banner / wide gameplay screenshots (16:9) */
  .gallery-slot--landscape {
    width: 427px;
    height: 240px;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: brightness(0.9);
    transition: filter 0.2s;
  }

  .gallery-slot:hover .gallery-img {
    filter: brightness(1);
  }

  .gallery-video {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .gallery-img[data-lightbox] {
    cursor: zoom-in;
  }

  /* Lightbox */
  #lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.88);
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
  }

  #lightbox.open {
    display: flex;
    animation: lb-in 0.18s ease-out;
  }

  @keyframes lb-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  #lightbox img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.8);
    animation: lb-scale 0.18s ease-out;
    cursor: zoom-out;
  }

  @keyframes lb-scale {
    from { transform: scale(0.93); }
    to   { transform: scale(1); }
  }

  #lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: #888;
    background: none;
    border: 1px solid #333;
    border-radius: 3px;
    padding: 4px 10px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  #lightbox-close:hover {
    color: #e2e2e2;
    border-color: #555;
  }
</style>

<script>
  const lb      = document.getElementById('lightbox')!;
  const lbImg   = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbClose = document.getElementById('lightbox-close')!;

  function open(src: string, alt: string) {
    lbImg.src = src;
    lbImg.alt = alt;
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lb.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLImageElement>('img[data-lightbox]').forEach(img => {
    img.addEventListener('click', () => open(img.src, img.alt));
  });

  lbClose.addEventListener('click', close);
  lb.addEventListener('click', e => { if (e.target === lb) close(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
</script>
