---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;

function toEmbedUrl(watchUrl: string) {
  const id = new URL(watchUrl).searchParams.get('v');
  return `https://www.youtube.com/embed/${id}?rel=0&modestbranding=1`;
}

function toThumbnailUrl(watchUrl: string) {
  const id = new URL(watchUrl).searchParams.get('v');
  return `https://img.youtube.com/vi/${id}/hqdefault.jpg`;
}

type Project = (typeof siteConfig.projects)[number];

// Pick the single most prominent CTA to surface in the header.
// Priority: webgl → steam → googlePlay → appStore → itchio → epic → legacy link → videoDemo
function pickPrimaryCta(p: Project) {
  const d = p.distribution;
  if (d?.webgl)       return { label: "PLAY NOW",      url: d.webgl,       kind: "primary" as const };
  if (d?.steam)       return { label: "VIEW ON STEAM", url: d.steam,       kind: "primary" as const };
  if (d?.googlePlay)  return { label: "GOOGLE PLAY",   url: d.googlePlay,  kind: "primary" as const };
  if (d?.appStore)    return { label: "APP STORE",     url: d.appStore,    kind: "primary" as const };
  if (d?.itchio)      return { label: "ITCH.IO",       url: d.itchio,      kind: "primary" as const };
  if (d?.epic)        return { label: "EPIC STORE",    url: d.epic,        kind: "primary" as const };
  if (p.link)         return { label: "OPEN ↗",        url: p.link,        kind: "primary" as const };
  if (p.videoDemo)    return { label: "VIDEO DEMO ▶",  url: p.videoDemo,   kind: "demo"    as const };
  return null;
}

function hasAnyDistribution(p: Project) {
  const d = p.distribution;
  return !!(d?.webgl || d?.googlePlay || d?.appStore || d?.steam || d?.itchio || d?.epic);
}
---

{hasProjects && (
  <section id="projects" class="section-pad" aria-labelledby="projects-heading" style="background: var(--bg-base)">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10 items-start">

      <!-- Section header -->
      <div class="lg:col-span-2">
        <p class="mono text-xs tracking-[0.2em] text-[var(--text-muted)] uppercase mb-2">SECTION_02</p>
        <h2 id="projects-heading" class="text-3xl sm:text-4xl xl:text-5xl font-bold text-[var(--text-primary)]">Projects</h2>
        <div class="w-12 h-0.5 mt-3 accent-rule"></div>
      </div>

      <!-- Asset cards -->
      <div class="lg:col-span-10 space-y-4">
        {siteConfig.projects.map((project) => {
          const hasExpandable = !!(
            project.responsibilities ||
            (project.coreSystems && project.coreSystems.length > 0) ||
            project.devLog ||
            (project.frontendStack && project.frontendStack.length > 0) ||
            (project.backendStack && project.backendStack.length > 0)
          );
          return (
          <div class="asset-card card-panel group" data-expanded="false">

            <!-- Screenshot / video gallery -->
            {(project.images?.length || project.videos?.length) && (
              <div class="asset-gallery" style="border-bottom: 1px solid var(--border)">
                {project.images?.map((src, i) => (
                  <div class={`gallery-slot gallery-slot--${project.imageLayout ?? "landscape"}`}>
                    <img
                      src={src}
                      alt={`${project.name} screenshot ${i + 1}`}
                      class="gallery-img"
                      loading="lazy"
                      data-lightbox
                      role="button"
                      tabindex="0"
                      aria-label={`Open screenshot ${i + 1} of ${project.images!.length} — ${project.name}`}
                    />
                  </div>
                ))}
                {project.videos?.map((url) => (
                  <div class={`gallery-slot gallery-slot--${project.imageLayout ?? "landscape"}`}>
                    <div
                      class="video-thumb"
                      data-embed={toEmbedUrl(url) + "&autoplay=1"}
                      role="button"
                      tabindex="0"
                      aria-label={`Play video demo — ${project.name}`}
                    >
                      <img src={toThumbnailUrl(url)} alt="Video thumbnail" class="gallery-img" />
                      <div class="play-btn">&#9654;</div>
                    </div>
                  </div>
                ))}
              </div>
            )}

            {(() => {
              const cta = !hasAnyDistribution(project) ? pickPrimaryCta(project) : null;
              return (
                <div class="px-4 py-3" style="border-bottom: 1px solid var(--border)">
                  <div class="flex items-start gap-3">
                    {project.icon && (
                      <img
                        src={project.icon}
                        alt=""
                        aria-hidden="true"
                        width="72"
                        height="72"
                        class="project-icon"
                        loading="lazy"
                      />
                    )}
                    <div class="flex-1 min-w-0">
                      <div class={`flex items-center gap-3 mb-2 ${cta ? 'justify-between' : ''}`}>
                        <span class="text-sm font-semibold text-[var(--text-primary)] truncate">{project.name}</span>
                        {cta && (
                          <a
                            href={cta.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class={`cta-btn cta-btn--${cta.kind} mono`}
                            style={cta.kind === "primary" ? `--cta: ${siteConfig.accentColor}` : undefined}
                            aria-label={`${cta.label} — ${project.name}`}
                          >
                            {cta.label}
                          </a>
                        )}
                      </div>
                      <p class="text-sm sm:text-base text-[var(--text-secondary)] leading-relaxed">
                        {project.description}
                      </p>
                    </div>
                  </div>
                </div>
              );
            })()}

            <!-- Distribution (always visible) -->
            {(hasAnyDistribution(project) || project.sourceCode) && (
              <div class="distribution" style="border-top: 1px solid var(--border)">
                <div class="distribution-buttons">
                  {project.distribution?.webgl && (
                    <a href={project.distribution.webgl} target="_blank" rel="noopener noreferrer"
                      class="store-btn mono" aria-label={`Play ${project.name} in browser`}>
                      <span class="store-icon">▶</span> Play in Browser
                    </a>
                  )}
                  {project.distribution?.googlePlay && (
                    <a href={project.distribution.googlePlay} target="_blank" rel="noopener noreferrer"
                      class="store-btn store-btn--google mono" aria-label={`${project.name} on Google Play`}>
                      <span class="store-icon">▶</span> Google Play
                    </a>
                  )}
                  {project.distribution?.appStore && (
                    <a href={project.distribution.appStore} target="_blank" rel="noopener noreferrer"
                      class="store-btn store-btn--apple mono" aria-label={`${project.name} on App Store`}>
                      <span class="store-icon"></span> App Store
                    </a>
                  )}
                  {project.distribution?.steam && (
                    <a href={project.distribution.steam} target="_blank" rel="noopener noreferrer"
                      class="store-btn store-btn--steam mono" aria-label={`${project.name} on Steam`}>
                      <span class="store-icon">⚙</span> Steam
                    </a>
                  )}
                  {project.distribution?.itchio && (
                    <a href={project.distribution.itchio} target="_blank" rel="noopener noreferrer"
                      class="store-btn store-btn--itchio mono" aria-label={`${project.name} on itch.io`}>
                      <span class="store-icon">◆</span> itch.io
                    </a>
                  )}
                  {project.distribution?.epic && (
                    <a href={project.distribution.epic} target="_blank" rel="noopener noreferrer"
                      class="store-btn store-btn--epic mono" aria-label={`${project.name} on Epic Games`}>
                      <span class="store-icon">◈</span> Epic Games
                    </a>
                  )}
                  {project.sourceCode === "proprietary" ? (
                    <span class="store-btn store-btn--locked mono" title="Source code withheld under NDA / PDPA">
                      <span class="store-icon">🔒</span> Proprietary Code
                    </span>
                  ) : project.sourceCode ? (
                    <a href={project.sourceCode} target="_blank" rel="noopener noreferrer"
                      class="store-btn mono">
                      <span class="store-icon">&#60;/&#62;</span> Source Code
                    </a>
                  ) : null}
                </div>
              </div>
            )}

            <!-- READ MORE toggle (hidden when expanded) -->
            {hasExpandable && (
              <button
                class="expand-toggle expand-toggle--more mono"
                type="button"
                data-expand-toggle
                aria-expanded="false"
                aria-label={`Expand details for ${project.name}`}
              >
                READ MORE <span class="expand-chevron">▾</span>
              </button>
            )}

            <!-- Expandable block -->
            <div class="expandable">
              <!-- Role & Responsibility -->
              {project.responsibilities && (
                <div class="px-4 py-4" style="border-top: 1px solid var(--border)">
                  <h4 class="mono section-label">// Role &amp; Responsibility</h4>
                  <p class="tech-body">{project.responsibilities}</p>
                </div>
              )}

              <!-- Core Systems Developed -->
              {project.coreSystems && project.coreSystems.length > 0 && (
                <div class="px-4 py-4" style="border-top: 1px solid var(--border)">
                  <h4 class="mono section-label">// Core Systems Developed</h4>
                  <ul class="tech-list">
                    {project.coreSystems.map((system) => (
                      <li>
                        <span class="mono tech-bullet" style={`color: ${siteConfig.accentColor}`}>→</span>
                        <span>{system}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              <!-- Dev Log -->
              {project.devLog && (
                <div class="px-4 py-4" style="border-top: 1px solid var(--border)">
                  <h4 class="mono section-label">
                    {project.devLog.title ? `// Dev Log — ${project.devLog.title}` : '// Dev Log'}
                  </h4>
                  <div class="space-y-4">
                    <div>
                      <span class="mono devlog-label" style="color: var(--accent-warning)">CHALLENGE</span>
                      <p class="tech-body mt-1">{project.devLog.challenge}</p>
                    </div>
                    <div>
                      <span class="mono devlog-label" style={`color: ${siteConfig.accentColor}`}>SOLUTION</span>
                      <p class="tech-body mt-1">{project.devLog.solution}</p>
                    </div>
                  </div>
                </div>
              )}

              <!-- Metadata bar -->
              {(project.role || project.genre || project.devTime || project.status) && (
                <div class="px-4 py-3 flex flex-wrap gap-x-6 gap-y-1"
                  style="border-top: 1px solid var(--border); background: rgba(255,255,255,0.02)">
                  {project.role && (
                    <span class="mono text-xs text-[var(--text-secondary)]">
                      ROLE: <span class="text-[var(--text-secondary)]">{project.role}</span>
                    </span>
                  )}
                  {project.genre && (
                    <span class="mono text-xs text-[var(--text-secondary)]">
                      GENRE: <span class="text-[var(--text-secondary)]">{project.genre}</span>
                    </span>
                  )}
                  {project.devTime && (
                    <span class="mono text-xs text-[var(--text-secondary)]">
                      DEV TIME: <span class="text-[var(--text-secondary)]">{project.devTime}</span>
                    </span>
                  )}
                  {project.status && (
                    <span class="mono text-xs text-[var(--text-secondary)]">
                      STATUS: {project.status === "Out of Service"
                        ? <span style="color: #666">✕ OUT OF SERVICE</span>
                        : project.status === "Unreleased"
                        ? <span style="color: #888">◌ UNRELEASED</span>
                        : project.status === "Thesis"
                        ? <span style="color: #888">◈ THESIS</span>
                        : <span style={`color: ${siteConfig.accentColor}`}>✓ {project.status.toUpperCase()}</span>
                      }
                    </span>
                  )}
                </div>
              )}

              <!-- Skill tags -->
              {((project.frontendStack && project.frontendStack.length > 0) ||
                (project.backendStack && project.backendStack.length > 0)) && (
                <div class="px-4 py-3 space-y-3"
                  style="border-top: 1px solid var(--border)">
                  {project.frontendStack && project.frontendStack.length > 0 && (
                    <div>
                      <h4 class="mono section-label">// Frontend Stack</h4>
                      <div class="flex flex-wrap gap-2">
                        {project.frontendStack.map((item) => (
                          <span class="tag tag--frontend">
                            {item.engine}{item.lang ? `-${item.lang}` : ''}
                          </span>
                        ))}
                      </div>
                    </div>
                  )}
                  {project.backendStack && project.backendStack.length > 0 && (
                    <div>
                      <h4 class="mono section-label">// Backend Stack</h4>
                      <div class="flex flex-wrap gap-2">
                        {project.backendStack.map((item) => (
                          <span class="tag tag--backend">
                            {item.engine}{item.lang ? `-${item.lang}` : ''}
                          </span>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              )}

              <!-- SHOW LESS (bottom of expandable) -->
              <button
                class="expand-toggle expand-toggle--less mono"
                type="button"
                data-expand-toggle
                aria-expanded="true"
                aria-label={`Collapse details for ${project.name}`}
              >
                SHOW LESS <span class="expand-chevron">▴</span>
              </button>
            </div>
            <!-- /expandable -->

          </div>
          );
        })}
      </div>

    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" role="dialog" aria-modal="true" aria-label="Image preview">
    <button id="lightbox-close" aria-label="Close">ESC ✕</button>
    <button id="lightbox-prev" aria-label="Previous">&#8592;</button>
    <img id="lightbox-img" src="" alt="" />
    <iframe id="lightbox-video" src="" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    <button id="lightbox-next" aria-label="Next">&#8594;</button>
  </div>
)}

<style>
  .project-icon {
    width: 72px;
    height: 72px;
    border-radius: 14px;
    object-fit: cover;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .asset-card {
    overflow: hidden;
    transition: box-shadow 0.25s ease;
  }
  .asset-card:hover {
    box-shadow: 0 0 0 1px var(--border-bright), 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  /* ── Expand / collapse ───────────────────────────────── */
  .expand-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    min-height: 44px;
    padding: 10px 16px;
    border-top: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.015);
    color: var(--text-secondary);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .expand-toggle:hover {
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-primary);
  }

  .expand-chevron {
    font-size: 0.9rem;
    line-height: 1;
  }

  /* Collapsed: expandable hidden, READ MORE visible */
  .asset-card[data-expanded="false"] .expandable { display: none; }

  /* Expanded: READ MORE hidden */
  .asset-card[data-expanded="true"] .expand-toggle--more { display: none; }

  /* ── Primary CTA (header) ────────────────────────────── */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    min-height: 44px;
    padding: 6px 14px;
    border-radius: 3px;
    white-space: nowrap;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
    flex-shrink: 0;
  }

  .cta-btn--primary {
    color: #000;
    background: var(--cta);
    border: 1px solid var(--cta);
    box-shadow: 0 0 0 0 rgba(0,0,0,0), 0 0 14px -4px color-mix(in srgb, var(--cta) 70%, transparent);
    font-weight: 600;
  }

  .cta-btn--primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 0 1px var(--cta), 0 0 24px -2px color-mix(in srgb, var(--cta) 75%, transparent);
  }

  .cta-btn--demo {
    color: var(--text-primary);
    background: transparent;
    border: 1px solid var(--border-bright);
  }

  .cta-btn--demo:hover {
    background: rgba(255,255,255,0.04);
    border-color: var(--text-secondary);
  }

  /* ── Technical depth sections ────────────────────────── */
  .section-label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    color: var(--text-secondary);
    text-transform: uppercase;
    margin-bottom: 10px;
    border-left: 2px solid var(--accent);
    padding-left: 8px;
  }

  .tech-label {
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .tech-body {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .tech-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .tech-list li {
    display: flex;
    gap: 10px;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .tech-bullet {
    flex-shrink: 0;
    font-weight: 600;
  }

  .devlog-label {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    margin-bottom: 4px;
  }

  /* ── Distribution row ────────────────────────────────── */
  .distribution {
    padding: 12px 16px;
  }

  .distribution-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .store-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    min-height: 44px;
    padding: 5px 14px;
    border-radius: 3px;
    border: 1px solid var(--store-color, var(--accent));
    color: var(--store-text, #000);
    background: var(--store-color, var(--accent));
    font-weight: 600;
    box-shadow: 0 0 14px -4px color-mix(in srgb, var(--store-color, var(--accent)) 70%, transparent);
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .store-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 0 1px var(--store-color, var(--accent)), 0 0 24px -2px color-mix(in srgb, var(--store-color, var(--accent)) 75%, transparent);
  }

  .store-btn--google { --store-color: var(--store-google); --store-text: #fff; }
  .store-btn--apple  { --store-color: var(--store-apple);  --store-text: #fff; }
  .store-btn--steam  { --store-color: var(--store-steam);  --store-text: #1b2838; }
  .store-btn--itchio { --store-color: var(--store-itchio); --store-text: #fff; }
  .store-btn--epic   { --store-color: var(--store-epic);   --store-text: #000; }

  .store-icon {
    font-size: 0.85rem;
  }

  .store-btn--locked {
    color: var(--accent-locked);
    background: transparent;
    border: 1px dashed var(--border-bright);
    box-shadow: none;
    font-weight: 400;
    cursor: default;
  }

  .store-btn--locked:hover {
    transform: none;
    box-shadow: none;
  }

  .asset-gallery {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    background: #0a0a0a;
  }

  .asset-gallery::-webkit-scrollbar {
    height: 3px;
  }
  .asset-gallery::-webkit-scrollbar-track {
    background: var(--border);
  }
  .asset-gallery::-webkit-scrollbar-thumb {
    background: var(--border-bright);
    border-radius: 2px;
  }

  .gallery-slot {
    flex-shrink: 0;
    overflow: hidden;
    scroll-snap-align: start;
  }

  /* Portrait — mobile game screenshots (9:16) */
  .gallery-slot--portrait {
    width: 180px;
    height: 320px;
  }

  /* Landscape — banner / wide gameplay screenshots (16:9) */
  .gallery-slot--landscape {
    width: 427px;
    height: 240px;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: brightness(0.9);
    transition: filter 0.2s;
  }

  .gallery-slot:hover .gallery-img {
    filter: brightness(1);
  }

  .video-thumb {
    position: relative;
    width: 100%;
    height: 100%;
    cursor: zoom-in;
  }

  .video-thumb .gallery-img {
    filter: brightness(0.7);
    transition: filter 0.2s;
  }

  .video-thumb:hover .gallery-img {
    filter: brightness(0.9);
  }

  .play-btn {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    color: rgba(255, 255, 255, 0.85);
    pointer-events: none;
    text-shadow: 0 2px 12px rgba(0,0,0,0.8);
  }

  #lightbox-video {
    display: none;
    width: 90vw;
    max-width: 960px;
    aspect-ratio: 16/9;
    border: none;
    border-radius: 4px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.8);
  }

  .gallery-img[data-lightbox] {
    cursor: zoom-in;
  }

  /* Lightbox */
  #lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.88);
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(6px);
  }

  #lightbox.open {
    display: flex;
    animation: lb-in 0.18s ease-out;
  }

  @keyframes lb-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  #lightbox img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.8);
    animation: lb-scale 0.18s ease-out;
    cursor: zoom-out;
  }

  @keyframes lb-scale {
    from { transform: scale(0.93); }
    to   { transform: scale(1); }
  }

  #lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: #888;
    background: none;
    border: 1px solid #333;
    border-radius: 3px;
    padding: 4px 10px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  #lightbox-close:hover {
    color: #e2e2e2;
    border-color: #555;
  }

  #lightbox-prev,
  #lightbox-next {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    font-size: 1.5rem;
    color: #888;
    background: transparent;
    border: none;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #lightbox-prev { left: 0; }
  #lightbox-next { right: 0; }

  #lightbox-prev:hover,
  #lightbox-next:hover {
    color: #e2e2e2;
    background: rgba(255, 255, 255, 0.05);
  }

  #lightbox-prev:disabled,
  #lightbox-next:disabled {
    opacity: 0.2;
    cursor: default;
  }

  /* ── Stack tag variants ──────────────────────────────── */
  .tag--frontend {
    background: rgba(245, 158, 11, 0.12);
    border-color: rgba(245, 158, 11, 0.45);
    color: #FCD34D;
  }

  .tag--backend {
    background: rgba(124, 58, 237, 0.12);
    border-color: rgba(124, 58, 237, 0.45);
    color: #C4B5FD;
  }

  /* ── Mobile gallery slot sizing ─────────────────────── */
  @media (max-width: 639px) {
    .gallery-slot--landscape {
      width: 290px;
      height: 163px;
    }
  }

  /* ── Reduced-motion (component-scoped animations) ───── */
  @media (prefers-reduced-motion: reduce) {
    #lightbox.open {
      animation: none;
    }

    #lightbox img {
      animation: none;
    }

    .cta-btn:hover,
    .store-btn:hover {
      transform: none !important;
    }
  }
</style>

<script>
  const lb       = document.getElementById('lightbox')!;
  const lbImg    = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbVid    = document.getElementById('lightbox-video') as HTMLIFrameElement;
  const lbClose  = document.getElementById('lightbox-close')!;
  const lbPrev   = document.getElementById('lightbox-prev') as HTMLButtonElement;
  const lbNext   = document.getElementById('lightbox-next') as HTMLButtonElement;

  type MediaItem = { type: 'image'; src: string; alt: string } | { type: 'video'; embed: string };

  let items: MediaItem[] = [];
  let currentIndex = 0;
  let lastFocus: HTMLElement | null = null;

  function show(index: number) {
    currentIndex = index;
    const item = items[currentIndex];

    if (item.type === 'image') {
      lbImg.src = item.src;
      lbImg.alt = item.alt;
      lbImg.style.display = 'block';
      lbVid.style.display = 'none';
      lbVid.src = '';
    } else {
      lbVid.src = item.embed;
      lbVid.style.display = 'block';
      lbImg.style.display = 'none';
    }

    lbPrev.disabled = currentIndex === 0;
    lbNext.disabled = currentIndex === items.length - 1;
  }

  function open(mediaItems: MediaItem[], index: number) {
    lastFocus = document.activeElement as HTMLElement;
    items = mediaItems;
    show(index);
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => lbClose.focus());
  }

  function close() {
    lb.classList.remove('open');
    lbVid.src = '';
    document.body.style.overflow = '';
    lastFocus?.focus();
  }

  function isFullyVisible(slot: Element, gallery: Element) {
    const s = slot.getBoundingClientRect();
    const g = gallery.getBoundingClientRect();
    return s.left >= g.left && s.right <= g.right;
  }

  document.querySelectorAll<HTMLElement>('.asset-gallery').forEach(gallery => {
    const mediaItems: MediaItem[] = [];

    gallery.querySelectorAll<HTMLImageElement>('img[data-lightbox]').forEach(img => {
      mediaItems.push({ type: 'image', src: img.src, alt: img.alt });
    });

    gallery.querySelectorAll<HTMLElement>('.video-thumb').forEach(overlay => {
      mediaItems.push({ type: 'video', embed: overlay.dataset.embed! });
    });

    gallery.querySelectorAll<HTMLImageElement>('img[data-lightbox]').forEach((img, i) => {
      img.addEventListener('click', () => {
        const slot = img.closest('.gallery-slot')!;
        if (isFullyVisible(slot, gallery)) {
          open(mediaItems, i);
        } else {
          slot.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
      });
      img.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          img.click();
        }
      });
    });

    gallery.querySelectorAll<HTMLElement>('.video-thumb').forEach((overlay, i) => {
      const imgCount = gallery.querySelectorAll('img[data-lightbox]').length;
      overlay.addEventListener('click', () => {
        const slot = overlay.closest('.gallery-slot')!;
        if (isFullyVisible(slot, gallery)) {
          open(mediaItems, imgCount + i);
        } else {
          slot.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
      });
      overlay.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          overlay.click();
        }
      });
    });
  });

  /* Expand / collapse project cards */
  document.querySelectorAll<HTMLButtonElement>('[data-expand-toggle]').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.asset-card') as HTMLElement;
      const expanded = card.dataset.expanded === 'true';
      card.dataset.expanded = (!expanded).toString();
      card.querySelectorAll<HTMLElement>('[data-expand-toggle]').forEach(b => {
        b.setAttribute('aria-expanded', (!expanded).toString());
      });
    });
  });

  lbPrev.addEventListener('click', () => { if (currentIndex > 0) show(currentIndex - 1); });
  lbNext.addEventListener('click', () => { if (currentIndex < items.length - 1) show(currentIndex + 1); });
  lbClose.addEventListener('click', close);
  lb.addEventListener('click', e => { if (e.target === lb) close(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') { close(); return; }
    if (e.key === 'ArrowLeft') { lbPrev.click(); return; }
    if (e.key === 'ArrowRight') { lbNext.click(); return; }
    if (e.key === 'Tab') {
      const focusable = [lbClose, lbPrev, lbNext].filter(el => !el.disabled);
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }
  });
</script>
