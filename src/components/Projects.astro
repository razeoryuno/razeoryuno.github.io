---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{hasProjects && (
  <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24" style="background: var(--bg-base)">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">

      <!-- Section header -->
      <div class="lg:col-span-4">
        <p class="mono text-xs tracking-[0.2em] text-[var(--text-muted)] uppercase mb-2">SECTION_02</p>
        <h2 class="text-4xl sm:text-5xl xl:text-6xl font-bold text-[var(--text-primary)]">Projects</h2>
        <div class="w-16 h-0.5 mt-3" style={`background: ${siteConfig.accentColor}`}></div>
      </div>

      <!-- Asset cards -->
      <div class="lg:col-span-8 space-y-4">
        {siteConfig.projects.map((project, index) => (
          <div class="asset-card card-panel group">

            <!-- Card header bar -->
            <div class="asset-header flex items-center justify-between px-4 py-2.5"
              style="border-bottom: 1px solid var(--border)">
              <div class="flex items-center gap-3">
                <span class="mono text-xs text-[var(--text-muted)]">
                  {String(index + 1).padStart(2, '0')}.asset
                </span>
                <span class="text-sm font-semibold text-[var(--text-primary)]">{project.name}</span>
              </div>
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mono text-xs tracking-wider uppercase transition-colors"
                  style={`color: ${siteConfig.accentColor}`}
                  aria-label={`Open ${project.name}`}
                >
                  OPEN ↗
                </a>
              )}
            </div>

            <!-- Description -->
            <div class="px-4 py-4">
              <p class="text-sm sm:text-base text-[var(--text-secondary)] leading-relaxed">
                {project.description}
              </p>
            </div>

            <!-- Metadata bar -->
            {(project.role || project.engine || project.status) && (
              <div class="px-4 py-3 flex flex-wrap gap-x-6 gap-y-1"
                style="border-top: 1px solid var(--border); background: rgba(255,255,255,0.02)">
                {project.role && (
                  <span class="mono text-xs text-[var(--text-muted)]">
                    ROLE: <span class="text-[var(--text-secondary)]">{project.role}</span>
                  </span>
                )}
                {project.engine && (
                  <span class="mono text-xs text-[var(--text-muted)]">
                    ENGINE: <span class="text-[var(--text-secondary)]">{project.engine}</span>
                  </span>
                )}
                {project.status && (
                  <span class="mono text-xs text-[var(--text-muted)]">
                    STATUS: <span style={`color: ${siteConfig.accentColor}`}>✓ {project.status.toUpperCase()}</span>
                  </span>
                )}
              </div>
            )}

            <!-- Skill tags -->
            {project.skills && project.skills.length > 0 && (
              <div class="px-4 py-3 flex flex-wrap gap-2"
                style="border-top: 1px solid var(--border)">
                {project.skills.map((skill) => (
                  <span class="tag">{skill}</span>
                ))}
              </div>
            )}

          </div>
        ))}
      </div>

    </div>
  </section>
)}

<style>
  .asset-card {
    overflow: hidden;
    transition: box-shadow 0.25s ease;
  }
  .asset-card:hover {
    box-shadow: 0 0 0 1px var(--border-bright), 0 8px 32px rgba(0, 0, 0, 0.4);
  }
</style>
