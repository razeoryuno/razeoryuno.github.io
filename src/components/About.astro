---
import { siteConfig } from "../config";
---

<section id="about" class="p-8 sm:p-12 md:p-16 lg:p-24" style="background: var(--bg-panel)">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">

    <!-- Section header -->
    <div class="lg:col-span-4">
      <p class="mono text-xs tracking-[0.2em] text-[var(--text-muted)] uppercase mb-2">SECTION_01</p>
      <h2 class="text-4xl sm:text-5xl xl:text-6xl font-bold text-[var(--text-primary)]">About</h2>
      <div class="w-16 h-0.5 mt-3" style={`background: ${siteConfig.accentColor}`}></div>
    </div>

    <!-- Bio + skills -->
    <div class="lg:col-span-8 space-y-10">
      <p class="text-base sm:text-lg leading-relaxed text-[var(--text-secondary)]">
        {siteConfig.aboutMe}
      </p>

      <!-- Skill modules -->
      <div>
        <div class="flex items-center gap-4 mb-5">
          <span class="mono text-xs tracking-widest text-[var(--text-muted)] uppercase">// Skill Modules</span>
          <div class="flex-1 h-px bg-[var(--border)]"></div>
        </div>

        <div class="space-y-4">
          {siteConfig.skills.map((skill) => (
            <div>
              <div class="flex justify-between items-baseline mb-1.5">
                <span class="text-sm font-medium text-[var(--text-primary)]">{skill.name}</span>
                <span class="mono text-xs text-[var(--text-muted)]">{skill.level}%</span>
              </div>
              <div class="skill-track">
                <div
                  class="skill-fill"
                  style={`width: ${skill.level}%; background: linear-gradient(90deg, ${siteConfig.accentColor}cc, ${siteConfig.accentColor})`}
                ></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>
