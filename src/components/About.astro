---
import { siteConfig } from "../config";
---

<section id="about" class="section-pad" aria-labelledby="about-heading" style="background: var(--bg-panel)">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10 items-start">

    <!-- Section header -->
    <div class="lg:col-span-2">
      <p class="mono text-xs tracking-[0.2em] text-[var(--text-muted)] uppercase mb-2">SECTION_01</p>
      <h2 id="about-heading" class="text-3xl sm:text-4xl xl:text-5xl font-bold text-[var(--text-primary)]">About</h2>
      <div class="w-12 h-0.5 mt-3 accent-rule"></div>
    </div>

    <!-- Bio + skills -->
    <div class="lg:col-span-10 space-y-10">
      <p class="text-base sm:text-lg leading-relaxed text-[var(--text-secondary)]">
        {siteConfig.aboutMe}
      </p>

      <!-- Expertise -->
      <div class="space-y-6">
        {siteConfig.expertise.technical.length > 0 && (
          <div>
            <div class="flex items-center gap-4 mb-3">
              <span class="mono text-xs tracking-widest text-[var(--text-muted)] uppercase">// Technical</span>
              <div class="flex-1 h-px bg-[var(--border)]"></div>
            </div>
            <div class="flex flex-wrap gap-2">
              {siteConfig.expertise.technical.map((item) => (
                <span class="tag">{item}</span>
              ))}
            </div>
          </div>
        )}

        {siteConfig.expertise.domain.length > 0 && (
          <div>
            <div class="flex items-center gap-4 mb-3">
              <span class="mono text-xs tracking-widest text-[var(--text-muted)] uppercase">// Domain</span>
              <div class="flex-1 h-px bg-[var(--border)]"></div>
            </div>
            <div class="flex flex-wrap gap-2">
              {siteConfig.expertise.domain.map((item) => (
                <span class="tag">{item}</span>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

  </div>
</section>
